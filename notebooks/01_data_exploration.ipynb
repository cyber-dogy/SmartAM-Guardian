{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 01 - 数据探索\n",
    "\n",
    "**目标**: 理解 SmartAM Guardian 数据集的结构和分布\n",
    "\n",
    "**内容**:\n",
    "1. 环境配置与数据加载\n",
    "2. Metadata 统计分析\n",
    "3. 标签分布检查\n",
    "4. 工况（Condition）分布\n",
    "5. 能量密度分布\n",
    "6. 初步可视化"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. 环境配置"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 自动重载模块（方便修改data/下的代码后无需重启kernel）\n",
    "%load_ext autoreload\n",
    "%autoreload 2\n",
    "\n",
    "import sys\n",
    "from pathlib import Path\n",
    "\n",
    "# 添加项目根目录到路径\n",
    "project_root = Path().absolute().parent\n",
    "sys.path.insert(0, str(project_root))\n",
    "\n",
    "print(f\"项目根目录: {project_root}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 常用导入\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from collections import Counter\n",
    "\n",
    "# 设置中文字体（Windows）\n",
    "plt.rcParams['font.sans-serif'] = ['SimHei', 'DejaVu Sans']\n",
    "plt.rcParams['axes.unicode_minus'] = False\n",
    "\n",
    "# 设置显示选项\n",
    "pd.set_option('display.max_columns', None)\n",
    "pd.set_option('display.width', None)\n",
    "\n",
    "print(\"✅ 环境配置完成\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. 加载 Metadata"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 定义路径\n",
    "DATA_ROOT = project_root / \"Causal_Image_Data\"\n",
    "METADATA_PATH = DATA_ROOT / \"metadata.csv\"\n",
    "\n",
    "print(f\"数据目录: {DATA_ROOT}\")\n",
    "print(f\"Metadata: {METADATA_PATH}\")\n",
    "print(f\"Metadata存在: {METADATA_PATH.exists()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 加载数据\n",
    "df = pd.read_csv(METADATA_PATH)\n",
    "\n",
    "print(f\"总样本数: {len(df)}\")\n",
    "print(f\"\n字段信息:\")\n",
    "print(df.dtypes)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 查看前几行\n",
    "df.head(10)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. 基础统计"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 数值字段统计\n",
    "numeric_cols = ['layer_id', 'power_w', 'speed_mms', 'spacing_mm', 'energy_density']\n",
    "print(\"=== 数值字段统计 ===\")\n",
    "df[numeric_cols].describe()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 类别字段统计\n",
    "print(\"=== Condition 数量 ===\")\n",
    "print(f\"唯一Condition数: {df['condition_id'].nunique()}\")\n",
    "print(f\"\\nCondition列表:\")\n",
    "for i, cond in enumerate(sorted(df['condition_id'].unique()), 1):\n",
    "    count = len(df[df['condition_id'] == cond])\n",
    "    print(f\"  {i:2d}. {cond}: {count} samples\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. 标签分布分析"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 二分类标签分布\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "# 饼图\n",
    "label_counts = df['defect_label_binary'].value_counts().sort_index()\n",
    "labels = ['Normal (0)', 'Abnormal (1)']\n",
    "colors = ['#2ecc71', '#e74c3c']\n",
    "axes[0].pie(label_counts, labels=labels, autopct='%1.1f%%', colors=colors, startangle=90)\n",
    "axes[0].set_title('Binary Label Distribution')\n",
    "\n",
    "# 柱状图\n",
    "label_counts.plot(kind='bar', ax=axes[1], color=colors, rot=0)\n",
    "axes[1].set_title('Binary Label Counts')\n",
    "axes[1].set_xlabel('Label')\n",
    "axes[1].set_ylabel('Count')\n",
    "for i, v in enumerate(label_counts):\n",
    "    axes[1].text(i, v + 5, str(v), ha='center', va='bottom')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"正常样本: {label_counts.get(0, 0)} ({label_counts.get(0, 0)/len(df)*100:.1f}%)\")\n",
    "print(f\"异常样本: {label_counts.get(1, 0)} ({label_counts.get(1, 0)/len(df)*100:.1f}%)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 异常类型分布\n",
    "type_counts = df['defect_label_type'].value_counts()\n",
    "print(\"=== 异常类型分布 ===\")\n",
    "print(type_counts)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "type_counts.plot(kind='bar', ax=ax, color=['#2ecc71', '#e74c3c', '#3498db'], rot=0)\n",
    "ax.set_title('Defect Type Distribution')\n",
    "ax.set_xlabel('Defect Type')\n",
    "ax.set_ylabel('Count')\n",
    "for i, v in enumerate(type_counts):\n",
    "    ax.text(i, v + 5, str(v), ha='center', va='bottom')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. 角色（Role）分布"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Role分布\n",
    "role_counts = df['role'].value_counts()\n",
    "print(\"=== Role 分布 ===\")\n",
    "print(role_counts)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "role_counts.plot(kind='barh', ax=ax, color='steelblue')\n",
    "ax.set_title('Role Distribution')\n",
    "ax.set_xlabel('Count')\n",
    "\n",
    "# 添加数值标签\n",
    "for i, v in enumerate(role_counts):\n",
    "    ax.text(v + 1, i, str(v), va='center')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. 工艺参数分析"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 功率、速度、间距分布\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 4))\n",
    "\n",
    "# 功率分布\n",
    "power_counts = df['power_w'].value_counts().sort_index()\n",
    "power_counts.plot(kind='bar', ax=axes[0], color='coral', rot=0)\n",
    "axes[0].set_title('Power Distribution')\n",
    "axes[0].set_xlabel('Power (W)')\n",
    "axes[0].set_ylabel('Count')\n",
    "\n",
    "# 速度分布\n",
    "speed_counts = df['speed_mms'].value_counts().sort_index()\n",
    "speed_counts.plot(kind='bar', ax=axes[1], color='skyblue', rot=0)\n",
    "axes[1].set_title('Speed Distribution')\n",
    "axes[1].set_xlabel('Speed (mm/s)')\n",
    "\n",
    "# 间距分布\n",
    "spacing_counts = df['spacing_mm'].value_counts().sort_index()\n",
    "spacing_counts.plot(kind='bar', ax=axes[2], color='lightgreen', rot=0)\n",
    "axes[2].set_title('Spacing Distribution')\n",
    "axes[2].set_xlabel('Spacing (mm)')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"功率范围: {df['power_w'].min()} - {df['power_w'].max()} W\")\n",
    "print(f\"速度范围: {df['speed_mms'].min()} - {df['speed_mms'].max()} mm/s\")\n",
    "print(f\"间距范围: {df['spacing_mm'].min()} - {df['spacing_mm'].max()} mm\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 能量密度分布\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "# 直方图\n",
    "axes[0].hist(df['energy_density'], bins=20, color='mediumpurple', edgecolor='black', alpha=0.7)\n",
    "axes[0].set_title('Energy Density Distribution')\n",
    "axes[0].set_xlabel('Energy Density (J/mm²)')\n",
    "axes[0].set_ylabel('Count')\n",
    "axes[0].axvline(df['energy_density'].mean(), color='red', linestyle='--', label=f'Mean: {df["energy_density"].mean():.2f}')\n",
    "axes[0].legend()\n",
    "\n",
    "# 按标签分类的能量密度\n",
    "df.boxplot(column='energy_density', by='defect_label_binary', ax=axes[1])\n",
    "axes[1].set_title('Energy Density by Label')\n",
    "axes[1].set_xlabel('Label (0=Normal, 1=Abnormal)')\n",
    "axes[1].set_ylabel('Energy Density (J/mm²)')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"能量密度范围: {df['energy_density'].min():.2f} - {df['energy_density'].max():.2f} J/mm²\")\n",
    "print(f\"平均能量密度: {df['energy_density'].mean():.2f} ± {df['energy_density'].std():.2f} J/mm²\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. 工况（Condition）详细分析"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 每个Condition的样本数和标签分布\n",
    "condition_stats = df.groupby('condition_id').agg({\n",
    "    'layer_id': 'count',\n",
    "    'defect_label_binary': ['sum', 'mean'],\n",
    "    'energy_density': 'first',\n",
    "    'power_w': 'first',\n",
    "    'speed_mms': 'first',\n",
    "    'spacing_mm': 'first',\n",
    "    'scan_strategy': 'first',\n",
    "    'role': 'first'\n",
    "}).round(2)\n",
    "\n",
    "# 重命名列\n",
    "condition_stats.columns = ['sample_count', 'abnormal_count', 'abnormal_rate', \n",
    "                          'energy_density', 'power_w', 'speed_mms', \n",
    "                          'spacing_mm', 'scan_strategy', 'role']\n",
    "\n",
    "# 按role排序\n",
    "condition_stats = condition_stats.sort_values(['role', 'condition_id'])\n",
    "\n",
    "print(\"=== Condition 详细信息 ===\")\n",
    "condition_stats"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 可视化每个condition的异常率\n",
    "fig, ax = plt.subplots(figsize=(12, 8))\n",
    "\n",
    "# 按role分组着色\n",
    "role_colors = {\n",
    "    'source_train': '#2ecc71',\n",
    "    'source_repeat': '#27ae60',\n",
    "    'causal_intervention_high': '#e74c3c',\n",
    "    'causal_intervention_low': '#e67e22',\n",
    "    'causal_equiv_test': '#9b59b6',\n",
    "    'unseen_strategy_shift': '#3498db',\n",
    "    'unseen_texture_shift': '#1abc9c',\n",
    "    'unseen_param_shift': '#34495e',\n",
    "    'unseen_composite_shift': '#7f8c8d'\n",
    "}\n",
    "\n",
    "colors = [role_colors.get(role, 'gray') for role in condition_stats['role']]\n",
    "\n",
    "bars = ax.barh(range(len(condition_stats)), condition_stats['abnormal_rate'], color=colors)\n",
    "ax.set_yticks(range(len(condition_stats)))\n",
    "ax.set_yticklabels(condition_stats.index, fontsize=9)\n",
    "ax.set_xlabel('Abnormal Rate')\n",
    "ax.set_title('Abnormal Rate by Condition')\n",
    "ax.axvline(0.5, color='black', linestyle='--', alpha=0.3)\n",
    "\n",
    "# 添加数值标签\n",
    "for i, (idx, row) in enumerate(condition_stats.iterrows()):\n",
    "    ax.text(row['abnormal_rate'] + 0.02, i, f\"{row['abnormal_rate']:.0%}\", \n",
    "            va='center', fontsize=8)\n",
    "\n",
    "# 图例\n",
    "from matplotlib.patches import Patch\n",
    "legend_elements = [Patch(facecolor=color, label=role) \n",
    "                  for role, color in role_colors.items() \n",
    "                  if role in condition_stats['role'].values]\n",
    "ax.legend(handles=legend_elements, loc='lower right', fontsize=8)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. 数据质量检查"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 检查缺失值\n",
    "print(\"=== 缺失值检查 ===\")\n",
    "missing = df.isnull().sum()\n",
    "print(missing[missing > 0] if missing.sum() > 0 else \"✅ 无缺失值\")\n",
    "\n",
    "# 检查重复行\n",
    "duplicates = df.duplicated().sum()\n",
    "print(f\"\\n重复行数: {duplicates}\")\n",
    "\n",
    "# 检查重复的condition+layer组合\n",
    "dup_layers = df.groupby(['condition_id', 'layer_id']).size()\n",
    "dup_layers = dup_layers[dup_layers > 1]\n",
    "print(f\"\\n重复的condition+layer组合: {len(dup_layers)}\")\n",
    "if len(dup_layers) > 0:\n",
    "    print(dup_layers)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 检查图像文件是否存在\n",
    "print(\"=== 图像文件存在性检查 ===\")\n",
    "\n",
    "sample_size = min(100, len(df))  # 检查前100个\n",
    "missing_images = []\n",
    "\n",
    "for idx, row in df.head(sample_size).iterrows():\n",
    "    cond = row['condition_id']\n",
    "    layer = int(row['layer_id'])\n",
    "    img_dir = DATA_ROOT / \"images\" / cond / f\"L{layer:04d}\"\n",
    "    \n",
    "    for img_name in ['rgb_view1.jpg', 'rgb_view2.jpg', 'ir_before.jpg', 'ir_after.jpg']:\n",
    "        img_path = img_dir / img_name\n",
    "        if not img_path.exists():\n",
    "            missing_images.append(str(img_path.relative_to(project_root)))\n",
    "\n",
    "if missing_images:\n",
    "    print(f\"⚠️ 发现 {len(missing_images)} 个缺失图像 (前{sample_size}个样本中)\")\n",
    "    for p in missing_images[:10]:\n",
    "        print(f\"  - {p}\")\n",
    "else:\n",
    "    print(f\"✅ 前{sample_size}个样本的图像文件都存在\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. 小结与待探索问题"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 打印总结\n",
    "print(\"=\" * 60)\n",
    "print(\"📊 数据探索总结\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"总样本数: {len(df)}\")\n",
    "print(f\"Condition数: {df['condition_id'].nunique()}\")\n",
    "print(f\"样本/Condition: {len(df) / df['condition_id'].nunique():.1f}\")\n",
    "print(f\"\\n标签分布:\")\n",
    "print(f\"  - 正常: {(df['defect_label_binary']==0).sum()} ({(df['defect_label_binary']==0).mean()*100:.1f}%)\")\n",
    "print(f\"  - 异常: {(df['defect_label_binary']==1).sum()} ({(df['defect_label_binary']==1).mean()*100:.1f}%)\")\n",
    "print(f\"\\n能量密度:\")\n",
    "print(f\"  - 范围: {df['energy_density'].min():.2f} - {df['energy_density'].max():.2f}\")\n",
    "print(f\"  - 异常样本平均: {df[df['defect_label_binary']==1]['energy_density'].mean():.2f}\")\n",
    "print(f\"  - 正常样本平均: {df[df['defect_label_binary']==0]['energy_density'].mean():.2f}\")\n",
    "print(\"\\n待探索问题:\")\n",
    "print(\"  1. 不同role的图像特征差异?\")\n",
    "print(\"  2. 能量密度与异常标签的相关性?\")\n",
    "print(\"  3. 多模态图像的一致性?\")\n",
    "print(\"=\" * 60)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
